# ColonyOS Server Configuration
COLONIES_SERVER_HOST=localhost
COLONIES_SERVER_PORT=50080
COLONIES_INSECURE=true

# Colony Configuration
COLONIES_COLONY_NAME=dev
COLONIES_COLONY_PRVKEY=your-colony-private-key-here

# Executor Configuration
COLONIES_EXECUTOR_NAME=deployment-controller-1
COLONIES_EXECUTOR_TYPE=deployment-controller

# Optional: Use pre-registered executor instead of self-registration
# COLONIES_PRVKEY=your-executor-private-key-here
# COLONIES_EXECUTOR_ID=your-executor-id-here

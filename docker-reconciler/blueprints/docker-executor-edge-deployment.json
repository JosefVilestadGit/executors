{
  "kind": "ExecutorDeployment",
  "metadata": {
    "name": "docker-executor-edge"
  },
  "handler": {
    "executorType": "docker-reconciler-edge",
    "executorName": "docker-reconciler-edge"
  },
  "spec": {
    "image": "colonyos/dockerexecutor:v1.0.7",
    "replicas": 1,
    "executorType": "container-executor",
    "volumes": [
      {
        "host": "/var/run/docker.sock",
        "container": "/var/run/docker.sock"
      },
      {
        "host": "/tmp/colonies",
        "container": "/tmp/colonies"
      }
    ],
    "privileged": true,
    "env": {
      "EXECUTOR_TYPE": "container-executor",
      "EXECUTOR_HW_MODEL": "Edge Device",
      "EXECUTOR_HW_CPU": "ARM Cortex-A72",
      "EXECUTOR_HW_CPU_CORES": "4",
      "EXECUTOR_HW_MEM": "8 GB",
      "EXECUTOR_HW_STORAGE": "64 GB",
      "EXECUTOR_HW_PLATFORM": "linux",
      "EXECUTOR_HW_ARCHITECTURE": "arm64",
      "EXECUTOR_HW_GPU_NAME": "",
      "EXECUTOR_HW_GPU_COUNT": "0",
      "EXECUTOR_HW_GPU_MEM": "0",
      "EXECUTOR_HW_NODES": "1",
      "EXECUTOR_HW_GPU_NODES_COUNT": "0",
      "EXECUTOR_LOCATION_LONG": "0",
      "EXECUTOR_LOCATION_LAT": "0",
      "EXECUTOR_LOCATION_NAME": "Edge",
      "EXECUTOR_LOCATION_DESC": "Edge Device"
    }
  }
}

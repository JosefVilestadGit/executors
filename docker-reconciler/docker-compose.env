# ============================================================================
# DOCKER RECONCILER NODE CONFIGURATION
# ============================================================================
# This file configures a second docker-reconciler node (edge node)
# The first node is configured in the main colonies docker-compose.env
#
# Usage:
#   source docker-compose.env && docker-compose up -d
# ============================================================================

# ============================================================================
# COLONYOS SERVER CONNECTION
# ============================================================================
# Use the colonies server service name from the colonies_default network
# The service name 'colonies-server' resolves to the colonies server container
export COLONIES_SERVER_HOST="10.0.0.200" # REPLACE WITH YOUR SERVER IP ADDRESS
export COLONIES_SERVER_PORT="50080"
export COLONIES_TLS="false"

# ============================================================================
# COLONY CONFIGURATION
# ============================================================================
export COLONIES_COLONY_NAME="dev"
export COLONIES_COLONY_PRVKEY="ba949fa134981372d6da62b6a56f336ab4d843b22c02a4257dcf7d0d73097514"

# User credentials for blueprint management
export COLONIES_PRVKEY="ddf7f7791208083b6a9ed975a72684f6406a269cfa36f1b1c32045c0a71fff05"

# ============================================================================
# EXECUTOR CONFIGURATION
# ============================================================================
export COLONIES_EXECUTOR_TYPE="docker-reconciler"
export COLONIES_EXECUTOR_NAME="edge-docker-reconciler"
export COLONIES_EXECUTOR_LOCATION="edge"

# ============================================================================
# S3/MINIO CONFIGURATION
# ============================================================================
# These variables are auto-injected into deployed containers for filesystem sync
export AWS_S3_ENDPOINT="minio:9000"
export AWS_S3_ACCESSKEY="RrXN2vcLeHjBptG8a3Ay"
export AWS_S3_SECRETKEY="ivwLB0Luqomq65nNVmoo8fTBgxXgNvqYGC50VQN6"
export AWS_S3_REGION_KEY=""
export AWS_S3_BUCKET="colonies-prod"
export AWS_S3_TLS="false"
export AWS_S3_SKIPVERIFY="false"

# ============================================================================
# OPTIONAL: AUTO-ADD BLUEPRINT ON STARTUP
# ============================================================================
# Set both to auto-add a blueprint when the reconciler starts.
# The blueprint file must exist in the blueprints/ directory.
# Leave empty to skip blueprint auto-add.
export BLUEPRINT_NAME="edge-docker-executor"
export BLUEPRINT_FILE="edge-docker-executor-deployment.json"

# ============================================================================
# DOCKER NETWORK FOR DEPLOYED CONTAINERS
# ============================================================================
# Network name for containers deployed by this reconciler.
# Default is "reconciler_default".
# Use "colonies_default" when running alongside the main colonies docker-compose.
export DOCKER_NETWORK="reconciler_default"

# ============================================================================
# OPTIONAL: PRE-REGISTERED EXECUTOR
# ============================================================================
# If you pre-registered the executor, uncomment and set these:
# export COLONIES_PRVKEY="your-executor-private-key-here"
# export COLONIES_EXECUTOR_ID="your-executor-id-here"

{
  "kind": "ExecutorDeployment",
  "metadata": {
    "name": "docker-executor-apple-ultra"
  },
  "handler": {
    "executorType": "docker-reconciler-apple-ultra",
    "executorName": "docker-reconciler-apple-ultra"
  },
  "spec": {
    "image": "colonyos/dockerexecutor:v1.0.7",
    "replicas": 1,
    "executorType": "container-executor",
    "volumes": [
      {
        "host": "/var/run/docker.sock",
        "container": "/var/run/docker.sock"
      },
      {
        "host": "/tmp/colonies",
        "container": "/tmp/colonies"
      }
    ],
    "privileged": true,
    "env": {
      "EXECUTOR_TYPE": "container-executor",
      "EXECUTOR_HW_MODEL": "Mac Studio",
      "EXECUTOR_HW_CPU": "Apple M2 Ultra",
      "EXECUTOR_HW_CPU_CORES": "24",
      "EXECUTOR_HW_MEM": "64 GB",
      "EXECUTOR_HW_STORAGE": "2000 GB",
      "EXECUTOR_HW_PLATFORM": "darwin",
      "EXECUTOR_HW_ARCHITECTURE": "arm64",
      "EXECUTOR_HW_GPU_NAME": "Apple M2 Ultra GPU",
      "EXECUTOR_HW_GPU_COUNT": "1",
      "EXECUTOR_HW_GPU_MEM": "64 GB",
      "EXECUTOR_HW_NODES": "1",
      "EXECUTOR_HW_GPU_NODES_COUNT": "1",
      "EXECUTOR_LOCATION_LONG": "0",
      "EXECUTOR_LOCATION_LAT": "0",
      "EXECUTOR_LOCATION_NAME": "Apple Ultra",
      "EXECUTOR_LOCATION_DESC": "Mac Studio M2 Ultra"
    }
  }
}

# ============================================================================
# DOCKER RECONCILER NODE CONFIGURATION - Linux Server
# ============================================================================
# This file configures the docker-reconciler for the Linux server
# with Intel i9-13900K and RTX 3080 Ti
#
# Usage:
#   cd env/linux-server && source docker-compose.env && docker-compose up -d
# ============================================================================

# ============================================================================
# COLONYOS SERVER CONNECTION
# ============================================================================
export COLONIES_SERVER_HOST="10.0.0.200" # REPLACE WITH YOUR SERVER IP ADDRESS
export COLONIES_SERVER_PORT="50080"
export COLONIES_TLS="false"

# ============================================================================
# COLONY CONFIGURATION
# ============================================================================
export COLONIES_COLONY_NAME="dev"
export COLONIES_COLONY_PRVKEY="ba949fa134981372d6da62b6a56f336ab4d843b22c02a4257dcf7d0d73097514"

# User credentials for blueprint management
export COLONIES_PRVKEY="ddf7f7791208083b6a9ed975a72684f6406a269cfa36f1b1c32045c0a71fff05"

# ============================================================================
# EXECUTOR CONFIGURATION
# ============================================================================
export COLONIES_EXECUTOR_TYPE="docker-reconciler-home-linux-server"
export COLONIES_EXECUTOR_NAME="docker-reconciler-home-linux-server"
export COLONIES_EXECUTOR_LOCATION="Home"

# ============================================================================
# HARDWARE CONFIGURATION (for reconciler executor registration)
# ============================================================================
export EXECUTOR_HW_MODEL="Z790 Pro RS"
export EXECUTOR_HW_CPU="13th Gen Intel Core i9-13900K"
export EXECUTOR_HW_CPU_CORES="24"
export EXECUTOR_HW_MEM="64056 MB"
export EXECUTOR_HW_STORAGE="1000 GB"
export EXECUTOR_HW_PLATFORM="linux"
export EXECUTOR_HW_ARCHITECTURE="amd64"
export EXECUTOR_HW_GPU_NAME="NVIDIA GeForce RTX 3080 Ti"
export EXECUTOR_HW_GPU_COUNT="1"
export EXECUTOR_HW_GPU_MEM="12288 MB"
export EXECUTOR_HW_NODES="1"
export EXECUTOR_HW_GPU_NODES_COUNT="1"
export EXECUTOR_LOCATION_LONG="0"
export EXECUTOR_LOCATION_LAT="0"
export EXECUTOR_LOCATION_NAME="Home"
export EXECUTOR_LOCATION_DESC="Intel i9 + RTX 3080 Ti Server"

# ============================================================================
# S3/MINIO CONFIGURATION
# ============================================================================
export AWS_S3_ENDPOINT="minio:9000"
export AWS_S3_ACCESSKEY="RrXN2vcLeHjBptG8a3Ay"
export AWS_S3_SECRETKEY="ivwLB0Luqomq65nNVmoo8fTBgxXgNvqYGC50VQN6"
export AWS_S3_REGION_KEY=""
export AWS_S3_BUCKET="colonies-prod"
export AWS_S3_TLS="false"
export AWS_S3_SKIPVERIFY="false"

# ============================================================================
# OPTIONAL: AUTO-ADD BLUEPRINT ON STARTUP
# ============================================================================
# Set BLUEPRINT_NAME and BLUEPRINT_PATH to auto-add a blueprint on startup.
# BLUEPRINT_PATH should be an absolute path to the blueprint JSON file.
export BLUEPRINT_NAME="docker-executor-linux-server"
export BLUEPRINT_PATH="./blueprint.json"

# ============================================================================
# DOCKER NETWORK FOR DEPLOYED CONTAINERS
# ============================================================================
export DOCKER_NETWORK="reconciler_default"

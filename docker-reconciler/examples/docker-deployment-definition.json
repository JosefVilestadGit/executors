{
  "metadata": {
    "name": "docker-deployment"
  },
  "spec": {
    "group": "docker.colonyos.io",
    "version": "v1",
    "names": {
      "kind": "DockerDeployment",
      "plural": "dockerdeployments",
      "singular": "dockerdeployment"
    },
    "scope": "Namespaced",
    "schema": {
      "type": "object",
      "required": ["instances"],
      "properties": {
        "network": {
          "type": "object",
          "properties": {
            "name": {
              "type": "string",
              "description": "Docker network name"
            },
            "create": {
              "type": "boolean",
              "description": "Whether to create the network if it doesn't exist"
            },
            "driver": {
              "type": "string",
              "description": "Network driver (bridge, overlay, etc.)",
              "default": "bridge"
            }
          }
        },
        "instances": {
          "type": "array",
          "description": "List of container instances to deploy",
          "items": {
            "type": "object",
            "required": ["name", "type", "image"],
            "properties": {
              "name": {
                "type": "string",
                "description": "Container name"
              },
              "type": {
                "type": "string",
                "enum": ["container"],
                "description": "Instance type (currently only 'container' is supported)"
              },
              "image": {
                "type": "string",
                "description": "Docker image name with optional tag"
              },
              "command": {
                "type": "array",
                "items": {"type": "string"},
                "description": "Override container command"
              },
              "args": {
                "type": "array",
                "items": {"type": "string"},
                "description": "Arguments to the container command"
              },
              "environment": {
                "type": "object",
                "additionalProperties": {"type": "string"},
                "description": "Environment variables as key-value pairs"
              },
              "envFile": {
                "type": "string",
                "description": "Path to .env file on host"
              },
              "ports": {
                "type": "array",
                "description": "Port mappings",
                "items": {
                  "type": "object",
                  "required": ["container"],
                  "properties": {
                    "container": {
                      "type": "integer",
                      "description": "Container port"
                    },
                    "host": {
                      "type": "integer",
                      "description": "Host port (optional, defaults to same as container)"
                    },
                    "protocol": {
                      "type": "string",
                      "enum": ["tcp", "udp"],
                      "default": "tcp",
                      "description": "Protocol"
                    }
                  }
                }
              },
              "volumes": {
                "type": "array",
                "description": "Volume mounts",
                "items": {
                  "type": "object",
                  "required": ["type", "mountPath"],
                  "properties": {
                    "type": {
                      "type": "string",
                      "enum": ["bind", "named", "tmpfs"],
                      "description": "Volume type"
                    },
                    "hostPath": {
                      "type": "string",
                      "description": "Host path for bind mounts"
                    },
                    "name": {
                      "type": "string",
                      "description": "Volume name for named volumes"
                    },
                    "mountPath": {
                      "type": "string",
                      "description": "Mount path inside container"
                    },
                    "readOnly": {
                      "type": "boolean",
                      "default": false,
                      "description": "Mount as read-only"
                    }
                  }
                }
              },
              "dependsOn": {
                "type": "array",
                "items": {"type": "string"},
                "description": "List of container names this container depends on"
              },
              "restartPolicy": {
                "type": "string",
                "enum": ["no", "always", "on-failure", "unless-stopped"],
                "default": "unless-stopped",
                "description": "Container restart policy"
              },
              "healthcheck": {
                "type": "object",
                "properties": {
                  "test": {
                    "type": "string",
                    "description": "Healthcheck command"
                  },
                  "interval": {
                    "type": "string",
                    "description": "Time between checks (e.g., '30s')"
                  },
                  "timeout": {
                    "type": "string",
                    "description": "Timeout for each check (e.g., '10s')"
                  },
                  "retries": {
                    "type": "integer",
                    "description": "Number of retries before marking unhealthy"
                  },
                  "startPeriod": {
                    "type": "string",
                    "description": "Grace period before starting checks (e.g., '40s')"
                  }
                }
              },
              "resources": {
                "type": "object",
                "description": "Resource limits and reservations",
                "properties": {
                  "cpus": {
                    "type": "string",
                    "description": "CPU limit (e.g., '0.5', '2')"
                  },
                  "memory": {
                    "type": "string",
                    "description": "Memory limit (e.g., '512M', '2G')"
                  }
                }
              },
              "labels": {
                "type": "object",
                "additionalProperties": {"type": "string"},
                "description": "Container labels"
              },
              "privileged": {
                "type": "boolean",
                "default": false,
                "description": "Run container in privileged mode"
              },
              "user": {
                "type": "string",
                "description": "User to run as (e.g., '1000:1000')"
              },
              "workingDir": {
                "type": "string",
                "description": "Working directory inside container"
              },
              "hostname": {
                "type": "string",
                "description": "Container hostname"
              }
            }
          }
        }
      }
    },
    "handler": {
      "executorType": "docker-reconciler",
      "functionName": "reconcile"
    }
  }
}
